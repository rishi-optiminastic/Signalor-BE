# Production environment for Signalor backend.
# Fill in real values; this file is gitignored.

DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=api.signalor.ai

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SMTP_PASS=
SMTP_USER=apikey
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@signalor.ai

DATABASE_URL=

GOOGLE_API_KEY=
OPENROUTER_API_KEY=
ENCRYPTION_KEY=

GOOGLE_ANALYTICS_REDIRECT_URI=https://signalor.ai/settings/integrations/callback/google-analytics

# Shopify OAuth
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=https://api.signalor.ai/api/integrations/shopify/callback
SHOPIFY_SCOPES=read_customers,read_orders,read_products,read_content,write_content
SIGNALOR_SHOPIFY_APP_URL=https://app.signalor.ai
SHOPIFY_OAUTH_USE_INSTALL_CUSTOM_APP=false
SHOPIFY_APP_UNINSTALLED_WEBHOOK_URL=https://api.signalor.ai/api/integrations/shopify/webhooks/app-uninstalled

FRONTEND_BASE_URL=https://signalor.ai
CORS_ALLOWED_ORIGINS=https://signalor.ai

# WordPress.com OAuth
WPCOM_CLIENT_ID=
WPCOM_CLIENT_SECRET=
WPCOM_REDIRECT_URI=https://api.signalor.ai/api/integrations/wordpress/callback

SUBSCRIPTION_REQUIRED=true
ENFORCE_PLAN_LIMITS=true
REQUIRE_SUBSCRIPTION_FOR_INTEGRATIONS=true

# Dodo Payments — Live keys
DODO_API_KEY=
DODO_PRODUCT_ID=
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_PRO=
DODO_PRODUCT_ID_BUSINESS=
DODO_LIVE_MODE=true

SERPER_API_KEY=

DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
