# Template for env/local.env, env/staging.env, env/production.env.
# Copy this file to one of those names and fill in real values.
# Real env files are gitignored; this template is committed.

# ── Django ──────────────────────────────────────────────────────────
# config.settings.development for local; config.settings.production for staging/prod.
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=replace-with-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Google OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (SendGrid) ───────────────────────────────────────────────
SMTP_PASS=
SMTP_USER=apikey
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# ── Database (Postgres / Neon) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ── AI providers ───────────────────────────────────────────────────
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# ── Encryption key for stored OAuth tokens (Fernet) ────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── GA4 OAuth callback ─────────────────────────────────────────────
GOOGLE_ANALYTICS_REDIRECT_URI=http://localhost:3000/settings/integrations/callback/google-analytics

# ── Shopify OAuth (Partners app) ───────────────────────────────────
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:8000/api/integrations/shopify/callback
SHOPIFY_SCOPES=read_customers,read_orders,read_products,read_content,write_content
SIGNALOR_SHOPIFY_APP_URL=https://app.signalor.ai
SHOPIFY_OAUTH_USE_INSTALL_CUSTOM_APP=false
SHOPIFY_APP_UNINSTALLED_WEBHOOK_URL=

# ── Frontend base URL & CORS ───────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── WordPress.com OAuth ────────────────────────────────────────────
WPCOM_CLIENT_ID=
WPCOM_CLIENT_SECRET=
WPCOM_REDIRECT_URI=http://localhost:8000/api/integrations/wordpress/callback

# ── Subscription gates ─────────────────────────────────────────────
SUBSCRIPTION_REQUIRED=false
ENFORCE_PLAN_LIMITS=true
REQUIRE_SUBSCRIPTION_FOR_INTEGRATIONS=false

# ── Dodo Payments ──────────────────────────────────────────────────
DODO_API_KEY=
DODO_PRODUCT_ID=
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_PRO=
DODO_PRODUCT_ID_BUSINESS=
DODO_LIVE_MODE=false

# ── Search APIs ────────────────────────────────────────────────────
SERPER_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
