# ─────────────────────────────────────────────────────────────────────────
# Signalor backend — production env for the Hetzner Docker Compose stack.
#
#   cp stack.env.example stack.env   then fill in the blanks.
#   stack.env holds live secrets — it is gitignored, NEVER commit it.
#   (This .example file is committed to a PUBLIC repo: keep it placeholders-only.)
#
# Shared by web, worker (and the host-cron management commands via `exec`).
# Data stores are SELF-HOSTED on this box: the `db` and `redis` containers.
# ─────────────────────────────────────────────────────────────────────────

DJANGO_SETTINGS_MODULE=config.settings.production

# ── Core (REQUIRED — the app refuses to boot without these) ──────────────
# Generate a fresh, strong one: python -c "import secrets; print(secrets.token_urlsafe(64))"
# (Your current value is a "django-insecure-…" dev key — fine to reuse so existing
#  sessions survive, but ideally rotate to a real random key.)
SECRET_KEY=

# Your API hostname(s) + loopback (loopback lets the container healthcheck pass).
# Must include the hostname Caddy serves. Use api2.signalor.ai while validating.
ALLOWED_HOSTS=api2.signalor.ai,api.signalor.ai,localhost,127.0.0.1

# Comma-separated, scheme included. Used for CORS *and* CSRF trusted origins.
CORS_ALLOWED_ORIGINS=https://signalor.ai,https://www.signalor.ai

FRONTEND_BASE_URL=https://signalor.ai

# Fernet key for stored OAuth tokens. Rotating this orphans every connected
# integration (it decrypts saved tokens) — keep your existing value.
ENCRYPTION_KEY=

# ── Database — self-hosted Postgres (the `db` container) ─────────────────
# IMPORTANT: use the DB_* vars, NOT DATABASE_URL. production.py forces
# sslmode=require when DATABASE_URL is set, and the local Postgres container
# doesn't serve TLS — so DATABASE_URL would fail to connect. The DB_* path
# skips the SSL requirement. Leave DATABASE_URL unset.
DB_NAME=signalor
DB_USER=signalor
# Generate a strong one: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSWORD=
DB_HOST=db
DB_PORT=5432

# ── Redis — self-hosted (the `redis` container) ──────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# ── Django admin ─────────────────────────────────────────────────────────
ADMIN_URL=admin/

# ── Server-side screenshots (Chromium is baked into the image here) ──────
ENABLE_SERVER_SCREENSHOTS=1

# ── Plan / subscription gates ────────────────────────────────────────────
SUBSCRIPTION_REQUIRED=true
ENFORCE_PLAN_LIMITS=true
REQUIRE_SUBSCRIPTION_FOR_INTEGRATIONS=true

# ── AI / SERP providers (analyzer pipeline reads these) ──────────────────
OPENROUTER_API_KEY=
SERPER_API_KEY=
# Set if you also use the Gemini / DataForSEO paths:
GEMINI_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Email (SendGrid SMTP) ────────────────────────────────────────────────
# IMPORTANT: production.py reads EMAIL_HOST_USER / EMAIL_HOST_PASSWORD — NOT the
# SMTP_USER / SMTP_PASS names. For SendGrid: user is literally "apikey".
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@carboncut.co
INTERNAL_EMAILS=

# ── Google OAuth (GA4 + login) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ANALYTICS_REDIRECT_URI=https://signalor.ai/settings/integrations/callback/google-analytics

# ── Shopify app ──────────────────────────────────────────────────────────
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,read_customers
SHOPIFY_REDIRECT_URI=https://api.signalor.ai/api/integrations/shopify/callback/
SHOPIFY_APP_WEBHOOK_SECRET=
SHOPIFY_APP_UNINSTALLED_WEBHOOK_URL=https://api.signalor.ai/api/integrations/shopify/webhooks/app-uninstalled/

# ── WordPress.com OAuth ──────────────────────────────────────────────────
WPCOM_CLIENT_ID=
WPCOM_CLIENT_SECRET=
WPCOM_REDIRECT_URI=https://api.signalor.ai/api/integrations/wordpress/callback/

# ── Payments: Dodo ───────────────────────────────────────────────────────
DODO_API_KEY=
DODO_LIVE_MODE=true
DODO_PRODUCT_ID=
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_PRO=
DODO_PRODUCT_ID_BUSINESS=
DODO_WEBHOOK_SECRET=
DODO_REFEREE_DISCOUNT_ID=
DODO_REFERRER_DISCOUNT_ID=
DODO_REFEREE_DISCOUNT_CODE=
DODO_REFERRER_DISCOUNT_CODE=

# ── Payments: Stripe (if used) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_USD=
STRIPE_PRICE_ID_INR=
STRIPE_WEBHOOK_SECRET=

# ── Backblaze B2 (invoice PDF cache — optional; leave blank to disable) ──
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_ENDPOINT=
B2_REGION=

# ── OpenTelemetry → Better Stack (optional observability) ────────────────
OTEL_SERVICE_NAME=signalor-backend
OTEL_RESOURCE_ATTRIBUTES=service.name=signalor-backend,deployment.environment=production
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=https://s2446917.eu-fsn-3.betterstackdata.com
# Bearer token header, e.g. "Authorization=Bearer XXXX". Leave blank to disable export.
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=true
OTEL_PYTHON_LOG_CORRELATION=true
